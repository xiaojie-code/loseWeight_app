# Pose provider: mediapipe, movenet, baidu or tencent. All providers keep /pose/detect unchanged.
POSE_PROVIDER=mediapipe

# Google MediaPipe Pose server-side inference. Run with: npm run pose:mediapipe
MEDIAPIPE_POSE_ENDPOINT=http://127.0.0.1:3100/detect
MEDIAPIPE_TIMEOUT_MS=1800
# MEDIAPIPE_MODEL_COMPLEXITY=0
# MEDIAPIPE_MIN_DETECTION_CONFIDENCE=0.35
# MEDIAPIPE_MIN_TRACKING_CONFIDENCE=0.35

# MoveNet server-side inference. Use lightning for lower latency, thunder for higher accuracy.
# MOVENET_MODEL_TYPE=lightning
# MOVENET_MIN_POSE_SCORE=0.12
# MOVENET_MIN_KEYPOINT_SCORE=0.12
# Default local model path follows MOVENET_MODEL_TYPE, e.g. server/models/movenet/singlepose-lightning/4/model.json
# MOVENET_MODEL_PATH=
# Optional: serve a local TFJS MoveNet model and point this to its model.json.
# MOVENET_MODEL_URL=

# Baidu AI Cloud BODY / body_analysis credentials, only used when POSE_PROVIDER=baidu.
# Create an application in Baidu AI Cloud -> Human Body Analysis, then copy API Key and Secret Key.
BAIDU_BODY_API_KEY=
BAIDU_BODY_SECRET_KEY=

# Optional: use a pre-generated access token instead of API Key/Secret Key.
# BAIDU_BODY_ACCESS_TOKEN=

# Optional filtering thresholds. Defaults follow Baidu's recommendation.
# BAIDU_BODY_MIN_BOX_SCORE=0.03
# BAIDU_BODY_MIN_KEYPOINT_SCORE=0.2
# BAIDU_BODY_MIN_VALID_KEYPOINTS=4

# Legacy Tencent fallback, only used when POSE_PROVIDER=tencent.
# TENCENT_SECRET_ID=
# TENCENT_SECRET_KEY=
# TENCENT_REGION=ap-guangzhou
