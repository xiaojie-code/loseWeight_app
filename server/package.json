{
  "name": "loseweight-game-server",
  "version": "1.0.0",
  "description": "减肥拳击对战游戏服务端",
  "scripts": {
    "build": "nest build",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:prod": "node dist/main",
